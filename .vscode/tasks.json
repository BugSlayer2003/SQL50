{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run current SQL practice file",
      "type": "shell",
      "command": "py",
      "args": [
        "${workspaceFolder}\\scripts\\run_sql.py",
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
